{
  "private": true,
  "scripts": {
    "format": "prettier -w --cache '**/*.ts'",
    "lint": "eslint --cache '**/*.ts'",
    "typecheck": "tsc",
    "build": "esbuild --bundle --platform=node src/main.ts --outdir=dist --minify"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.2",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.9.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1",
    "@actions/http-client": "4.0.1",
    "@commitlint/config-conventional": "21.0.2",
    "@commitlint/format": "21.0.1",
    "@commitlint/lint": "21.0.2",
    "defu": "^6.1.7",
    "micromatch": "^4.0.8",
    "p-limit": "^7.3.0",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  }
