{
  "private": true,
  "scripts": {
    "format": "prettier -w --cache '**/*.ts'",
    "lint": "eslint --cache '**/*.ts'",
    "typecheck": "tsc",
    "build": "esbuild --bundle --platform=node src/main.ts --outdir=dist --minify"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.6",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1",
    "@actions/http-client": "4.0.1",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/format": "20.5.0",
    "@commitlint/lint": "20.5.0",
    "defu": "^6.1.7",
    "micromatch": "^4.0.8",
    "p-limit": "^7.3.0",
    "smol-toml": "^1.6.1",
    "zod": "^4.3.6"
  }
